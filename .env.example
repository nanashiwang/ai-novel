ENVIRONMENT=local
DATABASE_URL=postgresql+asyncpg://novelflow:novelflow@localhost:5432/novelflow
REDIS_URL=redis://localhost:6379/0
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
MODEL_GATEWAY_PROVIDER=openai
DEFAULT_MODEL=gpt-5.5
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
MODEL_GATEWAY_TIMEOUT_SECONDS=300

# 对外端口
FRONTEND_PORT=13000
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
TEMPORAL_PORT=7233

# 鉴权
JWT_SECRET=please-change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12

# 跨域
CORS_ORIGINS=http://localhost:13000,http://127.0.0.1:13000

# Refresh Cookie
REFRESH_COOKIE_NAME=novelflow_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAMESITE=lax
